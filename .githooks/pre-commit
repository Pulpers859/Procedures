#!/bin/sh

set -eu

pattern='(ghp_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}|sk-[A-Za-z0-9]{20,}|AIza[0-9A-Za-z_-]{20,}|AKIA[0-9A-Z]{16}|BEGIN [A-Z ]*PRIVATE KEY|xox[baprs]-[A-Za-z0-9-]{10,})'
files="$(git diff --cached --name-only --diff-filter=ACM)"

[ -z "$files" ] && exit 0

echo "$files" | while IFS= read -r file; do
  [ -f "$file" ] || continue
  [ "$file" = ".githooks/pre-commit" ] && continue
  if grep -IEn "$pattern" "$file" >/dev/null 2>&1; then
    echo "Potential secret detected in staged file: $file"
    echo "Commit blocked. Move live credentials into ignored local config files."
    exit 1
  fi
done
